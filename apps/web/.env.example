# Better-Auth + Prisma (Supabase Postgres)
DATABASE_URL=postgresql://...
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_MCP_URL=http://localhost:3000/api/mcp

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Analytics (OpenPanel)
NEXT_PUBLIC_OPENPANEL_CLIENT_ID=
OPENPANEL_CLIENT_SECRET=

# Error monitoring (Sentry)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
NEXT_PUBLIC_ENVIRONMENT=development

# Resend (waitlist / audiences)
RESEND_API_KEY=
RESEND_TOPIC_ID=cdb0d440-4825-412a-8152-29681e8155b7
# Optional legacy segment assignment
RESEND_AUDIENCE_ID=
# Secret for internal subscribe API (used by auth hook on sign-up)
SUBSCRIBE_SECRET=

# Upstash rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# MCP API (optional)
# MCP_TELEMETRY_DISABLED=true
# MCP_MAX_RESPONSE_CHARS=32000

# Optional local overrides
# ENABLE_REMOTE_DATA_FETCH=true
# GITHUB_SPONSORS_LOGIN=
# GITHUB_TOKEN=
# OPEN_COLLECTIVE_SLUG=front-end-checklist
