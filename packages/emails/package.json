{
  "name": "@repo/emails",
  "version": "0.0.0",
  "private": true,
  "description": "Shared Resend helpers and React Email templates for Front-End Checklist",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "lint": "biome check .",
    "preview": "email dev --dir ./emails --port 3001",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --watchman=false --passWithNoTests",
    "test:ci": "NODE_OPTIONS=--experimental-vm-modules jest --watchman=false --ci --passWithNoTests",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --watchman=false --coverage --ci --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-email": "^6.5.0",
    "resend": "^6.12.4"
  },
  "devDependencies": {
    "@repo/config-typescript": "workspace:^",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jest": "catalog:",
    "ts-jest": "catalog:",
    "typescript": "catalog:"
  }
}
