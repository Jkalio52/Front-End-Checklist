{
  "name": "@repo/types",
  "version": "0.0.1",
  "private": true,
  "description": "Shared TypeScript type definitions for Front-End Checklist",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "lint": "biome check .",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --passWithNoTests",
    "test:ci": "NODE_OPTIONS=--experimental-vm-modules jest --ci --passWithNoTests",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage --ci --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@repo/config-typescript": "workspace:^",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "jest": "catalog:",
    "ts-jest": "catalog:",
    "typescript": "catalog:"
  }
}
