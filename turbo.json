{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "env": [
        "DATABASE_URL",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "ENABLE_REMOTE_DATA_FETCH",
        "GITHUB_CLIENT_ID",
        "GITHUB_CLIENT_SECRET",
        "GITHUB_SPONSORS_LOGIN",
        "GITHUB_TOKEN",
        "NEXT_PUBLIC_OPENPANEL_CLIENT_ID",
        "NEXT_PUBLIC_MCP_URL",
        "NEXT_PUBLIC_SITE_URL",
        "OPENPANEL_CLIENT_SECRET",
        "OPENPANEL_SECRET_ID",
        "RESEND_API_KEY",
        "RESEND_AUDIENCE_ID",
        "RESEND_TOPIC_ID",
        "NEXT_PUBLIC_SENTRY_DSN",
        "SENTRY_DSN",
        "SENTRY_AUTH_TOKEN",
        "SENTRY_OTLP_TRACES_URL",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "SENTRY_PUBLIC_KEY",
        "SENTRY_VERCEL_LOG_DRAIN_URL",
        "SUBSCRIBE_SECRET",
        "KV_REST_API_TOKEN",
        "KV_REST_API_READ_ONLY_TOKEN",
        "KV_REST_API_URL",
        "KV_URL",
        "REDIS_URL",
        "UPSTASH_REDIS_REST_TOKEN",
        "UPSTASH_REDIS_REST_URL"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "build/**"]
    },
    "@repo/auth#build": {
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.tsx", "src/**/*.ts", "test/**/*.ts", "test/**/*.tsx"],
      "outputs": ["coverage/**"]
    },
    "test:ci": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.tsx", "src/**/*.ts", "test/**/*.ts", "test/**/*.tsx"],
      "outputs": ["coverage/**"],
      "cache": false
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.tsx", "src/**/*.ts", "test/**/*.ts", "test/**/*.tsx"],
      "outputs": ["coverage/**"],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.tsx", "src/**/*.ts", "**/*.json"],
      "cache": true
    },
    "e2e": {
      "dependsOn": ["build"],
      "inputs": ["e2e/**/*.ts", "e2e/**/*.tsx", "playwright.config.ts"],
      "outputs": ["playwright-report/**", "test-results/**"],
      "cache": false
    },
    "e2e:headed": {
      "dependsOn": ["build"],
      "cache": false
    },
    "e2e:ui": {
      "dependsOn": ["build"],
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
